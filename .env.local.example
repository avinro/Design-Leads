NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────
# Supabase (server-only — never NEXT_PUBLIC_)
# ─────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# Google Gmail OAuth 2.0
# Used by Nodemailer to send contact notifications.
# Required scope: https://mail.google.com/
# ─────────────────────────────────────────────
GMAIL_USER=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Who receives contact form notifications.
# Defaults to GMAIL_USER if not set.
CONTACT_NOTIFICATION_TO=

# ─────────────────────────────────────────────
# Google Gemini
# ─────────────────────────────────────────────
GEMINI_API_KEY=
# Read ONLY from server modules (lib/ai/*). Set to "true" to enable AI calls.
# Any value other than "true" (including empty) disables all AI calls gracefully.
NEXT_PUBLIC_AI_ENABLED=
